pipeline {
    agent {
        docker {
            image 'maven:3.9.6-eclipse-temurin-17'
            args '--user root -v /var/run/docker.sock:/var/run/docker.sock'
        }
    }

    stages {
        
        stage('Checkout') {
            steps {
                 sh 'echo passed'
                 // git branch: 'main', url: 'https://github.com/Ramesh1984-10/Jenkins-Zero-To-Hero.git'
            }
        }

        stage('Build and Test') {
            steps {
                sh 'ls -ltr'
                sh 'cd java-maven-sonar-argocd-helm-k8s/spring-boot-app && mvn clean install'
            }
        }

        stage('Static Code Analysis') {
            environment {
                SONAR_URL = "http://47.130.237.165:9000"
            }
            steps {
                withCredentials([string(credentialsId: 'sonarqube-1', variable: 'SONAR_AUTH_TOKEN')]) {
                    sh '''
                        export JAVA_HOME=$(dirname $(dirname $(readlink -f $(which java))))
                        cd java-maven-sonar-argocd-helm-k8s/spring-boot-app
                        mvn sonar:sonar -Dsonar.login=$SONAR_AUTH_TOKEN -Dsonar.host.url=${SONAR_URL}
                    '''
                }
            }
        }

        stage('Build and Push Docker Image') {
            environment {
                DOCKER_IMAGE = "rameshk1984/ultimate-cicd:${BUILD_NUMBER}"
                REGISTRY_CREDENTIALS = credentials('docker-cred')
            }
            steps {
                script {
                    sh '''
                        apt-get update -qq
                        apt-get install -y ca-certificates curl gnupg -qq
                        curl -fsSL https://download.docker.com/linux/ubuntu/gpg | gpg --dearmor -o /usr/share/keyrings/docker.gpg
                        echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/docker.gpg] https://download.docker.com/linux/ubuntu $(. /etc/os-release && echo $UBUNTU_CODENAME) stable" > /etc/apt/sources.list.d/docker.list
                        apt-get update -qq
                        apt-get install -y docker-ce-cli -qq
                        cd java-maven-sonar-argocd-helm-k8s/spring-boot-app
                        docker build -t ${DOCKER_IMAGE} .
                    '''
                    def dockerImage = docker.image("${DOCKER_IMAGE}")
                    docker.withRegistry('https://index.docker.io/v1/', 'docker-cred') {
                        dockerImage.push()
                    }
                }
            }
        }
        /*
        stage('Approval for Deployment') {
            steps {
                input message: 'Approve deployment to production?', ok: 'Deploy'
            }
        }
        */
        stage('Update Deployment File') {
            environment {
                GIT_REPO_NAME = "ansible-zero-to-hero"
                GIT_USER_NAME = "Ramesh1984-10"
            }
            steps {
                withCredentials([string(credentialsId: 'github', variable: 'GITHUB_TOKEN')]) {
                    sh '''
                        git clone https://${GITHUB_TOKEN}@github.com/${GIT_USER_NAME}/${GIT_REPO_NAME}.git
                        cd ${GIT_REPO_NAME}
                        git config user.email "84rameshjaat@gmail.com"
                        git config user.name "Ramesh Kharb"
                        sed -i "s|image: rameshk1984/ultimate-cicd:.*|image: rameshk1984/ultimate-cicd:${BUILD_NUMBER}|g" spring-boot-app-manifests/deployment.yml
                        git add spring-boot-app-manifests/deployment.yml
                        git commit -m "Update deployment image to version ${BUILD_NUMBER} [ci skip]"
                        git push origin main
                    '''
                }
            }
        }

    }

    post {
        always {
            cleanWs()
        }
    }
}
